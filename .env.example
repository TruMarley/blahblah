# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=...

# ── OpenAI (AI voice conversation) ────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Twilio ─────────────────────────────────────────────────────────────────────
# Get these from https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Buy a number at console.twilio.com → Phone Numbers → Buy a number
# Then set webhook: Voice → Incoming call → https://YOUR_URL/incoming-call
TWILIO_PHONE_NUMBER=+17865550100

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5050
HOST=0.0.0.0

# ── ngrok (expose local server for Twilio webhooks during dev) ─────────────────
# 1. brew install ngrok
# 2. ngrok http 5050
# 3. Copy the https://xxxx.ngrok-free.app URL
# 4. In Twilio console, set Voice webhook to: https://xxxx.ngrok-free.app/incoming-call
# PUBLIC_URL=https://xxxx.ngrok-free.app

# ── Google Calendar (optional) ─────────────────────────────────────────────────
# GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
